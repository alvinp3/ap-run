# ============================================================
# BQ Training App — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ── Anthropic AI Coach ─────────────────────────────────────
# Get your API key at https://console.anthropic.com
# Used server-side only via /api/coach — never exposed to browser
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ───────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
# Create a new project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key for server-side writes (coach conversations, logs)
# Keep this secret — only used in API routes, never in client code
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Weather API ────────────────────────────────────────────
# Get your key at https://openweathermap.org/api
# Free tier is sufficient (60 calls/min, 1M calls/month)
# Without this key, app returns mock 72°F data in development
WEATHER_API_KEY=your_openweathermap_key

# ── Garmin Connect Integration ─────────────────────────────
# Your Garmin Connect credentials for the Railway sync worker
# These are only used by the separate Railway cron service (NOT by Next.js)
# See: /services/garmin-sync/ for the worker setup
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# ── App Configuration ──────────────────────────────────────
# Public base URL for share links and PWA (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (set to "production" in Vercel automatically)
NODE_ENV=development

# ── Vercel Deployment (auto-populated by Vercel, do not set manually) ─
# VERCEL_URL=your-app.vercel.app
# VERCEL_ENV=production
